/dts-v1/;
/plugin/;

/{
    compatible = "raspberrypi,model-zero-2-w";

    fragment@0 {
        target-path = "/soc/gpio@7e200000";
        __overlay__ {
            spi0_pins: spi0_pins {
                brcm,pins = <9 10 11>;
                brcm,function = <4>;
            };
            spi0_cs_pins: spi0_cs_pins {
                brcm,pins = <8 7>;
                brcm,function = <4>;
            };
        };
    };

    fragment@1 {
        target-path = "/soc/spi@7e204000";
        __overlay__ {
            pinctrl-names = "default";
            pinctrl-0 = <&spi0_pins &spi0_cs_pins>;
            status = "okay";

            spidev0: spidev@0 {
                compatible = "spidev";
                reg = <0>;
                spi-max-frequency = <125000000>;
            };

            spidev1: spidev@1 {
                compatible = "spidev";
                reg = <1>;
                spi-max-frequency = <125000000>;
            };
        };
    };
};
